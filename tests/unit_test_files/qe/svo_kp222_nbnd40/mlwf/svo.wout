Input Parameters
----------------

[mean_field.qe]
name = 'svo'
nbnd = 40
outdir = '../out'
prefix = 'svo'

[wannier90.library_mode]
mean_field = 'svo'
prefix = 'svo'

    [wannier90.library_mode.shells]
    SO = [ 0 ]
    atoms = [ 0 ]
    dim = [ 3 ]
    irrep = [ 0 ]
    l = [ 2 ]
    sort = [ 0 ]

-- End of Input Parameters --

